# GAPI Server Environment Variables

# Authentication secret key (REQUIRED in production)
GAPI_AUTH_SECRET=your_secret_key_here

# Development mode - allows unauthenticated access (default: false)
GAPI_DEV_MODE=false

# CORS allowed origins (comma-separated)
GAPI_ALLOWED_ORIGINS=http://localhost:5173,chrome-extension://*

# Maximum upload size in bytes (default: 10MB)
GAPI_MAX_UPLOAD_SIZE=10485760

# SQLite database path
GAPI_DB_PATH=./gapi.db

# Image storage directory
GAPI_IMAGE_DIR=./images

# Rate limit per minute for general endpoints
GAPI_RATE_LIMIT=60
